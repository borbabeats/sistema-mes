// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Setor {
  id   Int     @id @default(autoincrement())
  nome String  @unique @db.VarChar(100)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @default(now()) @map("updated_at")
  deleted_at DateTime? @db.Timestamp
  
  usuarios Usuario[]
  maquinas Maquina[]
  ordensProducao OrdemProducao[]
  
  @@map("setores")
}

model Usuario {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(100)
  email         String?  @unique @db.VarChar(100)
  telefone      String?  @db.VarChar(20)
  senha         String   @db.VarChar(255)
  cargo         Cargo    @default(OPERADOR)
  turno         String?  @db.VarChar(50)
  photo_profile  String?  @db.VarChar(255) // URL da imagem de perfil no CDN
  setor_id      Int?     @map("setor_id")
  mantencoesResponsavel Manutencao[] @relation("ManutencaoResponsavel")
  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @default(now()) @map("updated_at")
  deleted_at    DateTime? @db.Timestamp
  
  setor               Setor?           @relation(fields: [setor_id], references: [id])
  apontamentos        Apontamento[]
  notificacaoDestinatarios NotificacaoDestinatario[]
  logNotificacoes     LogNotificacao[]
  ordensComoResponsavel OrdemProducao[] @relation("OrdemProducaoResponsavel")
  ordensComoOperador  OrdemProducao[]  @relation("OrdemProducaoOperadores")
  statusLogs          OrdemProducaoStatusLog[]
  
  @@map("usuarios")
}

model Maquina {
  id          Int               @id @default(autoincrement())
  codigo      String            @unique @db.VarChar(50)
  nome        String            @db.VarChar(100)
  descricao   String?           @db.VarChar(500)
  fabricante  String?           @db.VarChar(100)
  modelo      String?           @db.VarChar(100)
  numeroSerie String?           @map("numero_serie") @db.VarChar(100)
  anoFabricacao Int?            @map("ano_fabricacao")
  capacidade  String?           @db.VarChar(100)
  status      StatusMaquina     @default(DISPONIVEL)
  horasUso    Float             @default(0) @map("horas_uso")
  setor_id    Int?
  created_at  DateTime          @default(now()) @map("created_at")
  updated_at  DateTime          @updatedAt @map("updated_at")
  deleted_at  DateTime?         @db.Timestamp
  
  setor       Setor?            @relation(fields: [setor_id], references: [id])
  apontamentos Apontamento[]
  manutencoes Manutencao[]
  
  @@map("maquinas")
}

model Manutencao {
  id              Int               @id @default(autoincrement())
  maquinaId       Int               @map("maquina_id")
  tipo            TipoManutencao
  descricao       String            @db.VarChar(500)
  dataAgendada    DateTime          @map("data_agendada")
  dataInicio      DateTime?         @map("data_inicio")
  dataFim         DateTime?         @map("data_fim")
  status          StatusManutencao  @default(AGENDADA)
  custoEstimado   Decimal?            @map("custo_estimado") @db.Decimal(10,2)
  custoReal       Decimal?            @map("custo_real") @db.Decimal(10,2)
  responsavelId   Int?              @map("responsavel_id")
  observacoes     String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  maquina         Maquina           @relation(fields: [maquinaId], references: [id])
  responsavel     Usuario?          @relation("ManutencaoResponsavel", fields: [responsavelId], references: [id])
  historico       HistoricoManutencao[]
  
  @@map("manutencoes")
}

model HistoricoManutencao {
  id            Int         @id @default(autoincrement())
  manutencaoId  Int         @map("manutencao_id")
  statusAnterior String?     @map("status_anterior") @db.VarChar(50)
  statusNovo    String      @map("status_novo") @db.VarChar(50)
  descricao     String      @db.VarChar(500)
  dataRegistro  DateTime    @default(now()) @map("data_registro")
  
  manutencao    Manutencao  @relation(fields: [manutencaoId], references: [id])
  
  @@map("historico_manutencoes")
}

model OrdemProducao {
  id                   Int                @id @default(autoincrement())
  codigo               String             @unique @db.VarChar(50)
  produto              String             @db.VarChar(150)
  descricao            String?            @db.VarChar(500)
  quantidadePlanejada  Int
  quantidadeProduzida  Int                @default(0)
  status               StatusOP           @default(RASCUNHO)
  prioridade           PrioridadeOP       @default(MEDIA)
  dataInicioPlanejado  DateTime?
  dataFimPlanejado     DateTime?
  dataInicioReal       DateTime?
  dataFimReal          DateTime?
  setorId              Int
  responsavelId        Int?
  origemTipo           OrigemOP?          @default(PEDIDO_VENDA)
  origemId             String?            @db.VarChar(100)
  observacoes          String?            @db.Text
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")
  
  setor                Setor              @relation(fields: [setorId], references: [id])
  responsavel          Usuario?           @relation("OrdemProducaoResponsavel", fields: [responsavelId], references: [id])
  operadores           Usuario[]          @relation("OrdemProducaoOperadores")
  apontamentos         Apontamento[]
  statusLogs           OrdemProducaoStatusLog[]
  
  @@map("ordens_producao")
}

model Apontamento {
  id                   Int      @id @default(autoincrement())
  opId                 Int
  maquinaId            Int
  usuarioId            Int
  quantidadeProduzida  Int      @default(0)
  quantidadeDefeito    Int      @default(0)
  dataInicio           DateTime
  dataFim              DateTime?
  
  op      OrdemProducao @relation(fields: [opId], references: [id])
  maquina Maquina       @relation(fields: [maquinaId], references: [id])
  usuario Usuario       @relation(fields: [usuarioId], references: [id])
  
  @@map("apontamentos")
}

model ConfigNotificacao {
  id                Int                    @id @default(autoincrement())
  nome              String                 @db.VarChar(100)
  tipoEvento        TipoEventoNotificacao
  valorCritico      Decimal?                @db.Decimal(10, 2)
  enviarWhatsapp    Boolean                 @default(false)
  enviarWebSocket   Boolean                 @default(true)
  ativo             Boolean                 @default(true)
  
  notificacaoDestinatarios NotificacaoDestinatario[]
  logNotificacoes          LogNotificacao[]
  
  @@map("config_notificacoes")
}

model NotificacaoDestinatario {
  configId Int
  usuarioId Int
  
  config   ConfigNotificacao @relation(fields: [configId], references: [id])
  usuario  Usuario           @relation(fields: [usuarioId], references: [id])
  
  @@id([configId, usuarioId])
  @@map("notificacao_destinatarios")
}

model LogNotificacao {
  id         Int                   @id @default(autoincrement())
  configId   Int
  usuarioId  Int
  mensagem   String?
  dataEnvio  DateTime              @default(now())
  statusEnvio StatusEnvioNotificacao
  
  config  ConfigNotificacao @relation(fields: [configId], references: [id])
  usuario Usuario           @relation(fields: [usuarioId], references: [id])
  
  @@map("log_notificacoes")
}

enum Cargo {
  ADMIN
  GERENTE
  OPERADOR
}

enum PrioridadeOP {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusMaquina {
  DISPONIVEL
  EM_USO
  MANUTENCAO
  INATIVA
  PARADA
  DESATIVADA
}

enum TipoManutencao {
  PREVENTIVA
  CORRETIVA
  PREDITIVA
  LUBRIFICACAO
  CALIBRACAO
  OUTRA
}

enum StatusManutencao {
  AGENDADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
  ATRASADA
}

enum OrigemOP {
  PEDIDO_VENDA
  REPOSICAO_ESTOQUE
  PLANO_MESTRE_PRODUCAO
  DEMANDA_INTERNA
  PREVISAO_VENDAS
}

enum StatusOP {
  RASCUNHO
  PLANEJADA
  EM_ANDAMENTO
  PAUSADA
  FINALIZADA
  CANCELADA
  ATRASADA
}

enum TipoEventoNotificacao {
  MAQUINA_PARADA
  OP_ATRASADA
  DEFEITO_ALTO
  OP_FINALIZADA
}

enum StatusEnvioNotificacao {
  SUCESSO
  FALHA
}

model OrdemProducaoStatusLog {
  id           Int        @id @default(autoincrement())
  ordem_id     Int        @map("ordem_id")
  de_status     StatusOP   @map("de_status")
  para_status   StatusOP   @map("para_status")
  motivo       String?    @db.Text
  usuario_id   Int?       @map("usuario_id")
  created_at   DateTime   @default(now()) @map("created_at")
  
  ordemProducao OrdemProducao? @relation(fields: [ordem_id], references: [id], onDelete: Cascade)
  usuario       Usuario?       @relation(fields: [usuario_id], references: [id])
  
  @@map("ordem_producao_status_logs")
}
