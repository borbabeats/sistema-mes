{
  "name": "sistema_mes",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "docker:start": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:restart": "docker-compose -f docker-compose.dev.yml restart",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:down-v": "docker-compose -f docker-compose.dev.yml down -v",
    "prisma:seed": "npx prisma db seed --schema=./prisma/schema.prisma",
    "docker:build": "docker build -t sistema-mes .",
    "docker:run": "docker run -p 3000:3000 sistema-mes",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:prod-down": "docker-compose -f docker-compose.prod.yml down",
    "db:setup": "./scripts/setup-rds-database.sh $DATABASE_URL",
    "db:reset": "source $(pwd)/.env && if [ -z \"$DATABASE_URL\" ]; then echo 'DATABASE_URL is not set'; exit 1; fi; DATABASE_URL=\"$DATABASE_URL\" node -e \"const url = process.env.DATABASE_URL; const match = url.match(/mysql:\\/\\/(.*):(.*)@(.+):(.*)\\/(.+)/); if (match) { const [, user, pass, host, port, db] = match; console.log('mysql -h ' + host + ' -P ' + port + ' -u ' + user + ' -p' + pass + ' < scripts/reset-database.sql'); } else { console.error('Invalid DATABASE_URL format'); process.exit(1); }\" | bash",
    "db:migrate": "source $(pwd)/.env && DATABASE_URL=\"$DATABASE_URL\" npx prisma migrate deploy",
    "db:generate": "source $(pwd)/.env && DATABASE_URL=\"$DATABASE_URL\" npx prisma generate",
    "db:seed": "source $(pwd)/.env && DATABASE_URL=\"$DATABASE_URL\" npx ts-node prisma/seed.ts",
    "db:full": "npm run db:reset && npm run db:migrate && npm run db:generate && npm run db:seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.4",
    "@prisma/adapter-mariadb": "^7.2.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.3.1",
    "mariadb": "^3.4.5",
    "mysql2": "^3.16.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
